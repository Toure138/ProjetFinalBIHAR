{
  "title": "Temperature Forecast API",
  "uid": "temperature-api",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [

    {
      "id": 100,
      "title": "MONITORING MODELE — Predictions vs Observations",
      "type": "text",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 2 },
      "options": {
        "mode": "markdown",
        "content": "## Monitoring du modele LSTM — Comparaison predictions vs valeurs reelles (7 derniers jours)"
      }
    },

    {
      "id": 10,
      "title": "MAE — Erreur absolue moyenne (°C)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 2, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "model_monitoring_mae",
          "legendFormat": "MAE",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "decimals": 3,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" }
    },

    {
      "id": 11,
      "title": "RMSE (°C)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 2, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "model_monitoring_rmse",
          "legendFormat": "RMSE",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "decimals": 3,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1.5 },
              { "color": "red", "value": 4 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },

    {
      "id": 12,
      "title": "Biais moyen (°C)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 2, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "model_monitoring_bias",
          "legendFormat": "Biais",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "decimals": 3,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },

    {
      "id": 13,
      "title": "Points compares",
      "type": "stat",
      "gridPos": { "x": 18, "y": 2, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "model_monitoring_n_points",
          "legendFormat": "N points",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "green", "value": 50 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },

    {
      "id": 14,
      "title": "Predictions vs Observations — Temperature (°C)",
      "description": "Courbes predicted vs actual. Source : GET /monitoring/data via plugin Infinity.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 10 },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "infinity" },
      "targets": [
        {
          "refId": "predicted",
          "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "infinity" },
          "type": "json",
          "source": "url",
          "format": "timeseries",
          "url": "http://api:8000/monitoring/data?days=7",
          "url_options": { "method": "GET", "data": "" },
          "root_selector": "rows",
          "columns": [
            { "selector": "time", "text": "time", "type": "timestamp_iso" },
            { "selector": "predicted", "text": "Predicted", "type": "number" }
          ],
          "filters": [],
          "global_query_id": ""
        },
        {
          "refId": "actual",
          "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "infinity" },
          "type": "json",
          "source": "url",
          "format": "timeseries",
          "url": "http://api:8000/monitoring/data?days=7",
          "url_options": { "method": "GET", "data": "" },
          "root_selector": "rows",
          "columns": [
            { "selector": "time", "text": "time", "type": "timestamp_iso" },
            { "selector": "actual", "text": "Actual", "type": "number" }
          ],
          "filters": [],
          "global_query_id": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Actual" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "dark-blue", "mode": "fixed" } },
              { "id": "custom.lineWidth", "value": 2 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Predicted" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "dash": [8, 4], "fill": "dash" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      }
    },

    {
      "id": 15,
      "title": "Erreur (Predicted - Actual) en °C",
      "description": "Positif = surestimation, negatif = sous-estimation.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 7 },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "infinity" },
      "targets": [
        {
          "refId": "error",
          "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "infinity" },
          "type": "json",
          "source": "url",
          "format": "timeseries",
          "url": "http://api:8000/monitoring/data?days=7",
          "url_options": { "method": "GET", "data": "" },
          "root_selector": "rows",
          "columns": [
            { "selector": "time", "text": "time", "type": "timestamp_iso" },
            { "selector": "error", "text": "Erreur", "type": "number" }
          ],
          "filters": [],
          "global_query_id": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": { "fillOpacity": 20 }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      }
    },

    {
      "id": 101,
      "title": "MONITORING API — Trafic et performances",
      "type": "text",
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 2 },
      "options": {
        "mode": "markdown",
        "content": "## Monitoring de l'API — Trafic, latence et erreurs HTTP"
      }
    },

    {
      "id": 1,
      "title": "Requetes par seconde (RPS)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 25, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"temperature-api\"}[1m])",
          "legendFormat": "{{method}} {{handler}} {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } } }
    },

    {
      "id": 2,
      "title": "Latence des requetes (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 25, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(http_request_duration_highr_seconds_bucket{job=\"temperature-api\"}[1m]))",
          "legendFormat": "p50", "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_highr_seconds_bucket{job=\"temperature-api\"}[1m]))",
          "legendFormat": "p95", "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(http_request_duration_highr_seconds_bucket{job=\"temperature-api\"}[1m]))",
          "legendFormat": "p99", "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" } } }
    },

    {
      "id": 3,
      "title": "Total requetes",
      "type": "stat",
      "gridPos": { "x": 0, "y": 33, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(http_requests_total{job=\"temperature-api\"})", "refId": "A" }],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },

    {
      "id": 4,
      "title": "Taux d'erreurs 4xx/5xx",
      "type": "stat",
      "gridPos": { "x": 4, "y": 33, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum(rate(http_requests_total{job=\"temperature-api\", status=~\"[45]..\"}[5m])) / sum(rate(http_requests_total{job=\"temperature-api\"}[5m])) * 100",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": { "unit": "percent", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },

    {
      "id": 5,
      "title": "Latence moyenne",
      "type": "stat",
      "gridPos": { "x": 8, "y": 33, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum(rate(http_request_duration_highr_seconds_sum{job=\"temperature-api\"}[5m])) / sum(rate(http_request_duration_highr_seconds_count{job=\"temperature-api\"}[5m]))",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 1 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },

    {
      "id": 6,
      "title": "API en ligne (UP)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 33, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "up{job=\"temperature-api\"}", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": {
            "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" }
          }}],
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null }, { "color": "green", "value": 1 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },

    {
      "id": 7,
      "title": "Requetes par endpoint",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 37, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum by (handler) (rate(http_requests_total{job=\"temperature-api\"}[1m]))",
        "legendFormat": "{{handler}}", "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } } }
    },

    {
      "id": 8,
      "title": "Distribution des codes HTTP",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 37, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum by (status) (rate(http_requests_total{job=\"temperature-api\"}[1m]))",
        "legendFormat": "HTTP {{status}}", "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } } }
    }

  ]
}
